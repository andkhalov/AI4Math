# AI4Math .env — скопируй в .env и заполни своими значениями.
# Wizard `./cli/wizard.py` делает это автоматически при setup.sh.

# === Yandex AI Studio (обязательно) ===
YANDEX_AI_API=YOUR_API_KEY_HERE
YANDEX_CLOUD_FOLDER=YOUR_FOLDER_ID_HERE

# === Идентификаторы моделей (не трогай, если Yandex их не поменял) ===
YANDEX_QWEN=qwen3-235b-a22b-fp8/latest
YANDEX_DEEPSEEK=deepseek-v32/latest
YANDEX_GPTOOS=gpt-oss-120b/latest

# === Модель по умолчанию (qwen рекомендуется) ===
AI4MATH_MODEL=qwen

# === Lean checker (Docker-сервис для верификации Lean 4) ===
LEAN_CHECKER_URL=http://localhost:8888

# === Опционально: Brave Search API ===
# Если не задано — web_search падает в DuckDuckGo HTML (keyless).
# BRAVE_API_KEY=

# === Опциональные тюнинги Goose (обычно не надо трогать) ===
# GOOSE_CONTEXT_LIMIT=256000        # для qwen, иначе wrapper выставит сам
# GOOSE_AUTO_COMPACT_THRESHOLD=0.8
# GOOSE_MAX_TOKENS=16000
# GOOSE_TEMPERATURE=0.2
